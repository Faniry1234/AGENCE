# ========================================
# CONFIGURATION D'ENVIRONNEMENT
# Copier ce fichier en .env et modifier les valeurs
# ========================================

# Application Configuration
APP_NAME=Mada Voyage
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=madavoyage
DB_USER=root
DB_PASS=

# Session & Security
SESSION_TIMEOUT=3600
TIMEZONE=Indian/Antananarivo

# Upload Configuration (in bytes)
MAX_UPLOAD_SIZE=5242880

# Logging
LOG_PATH=logs/

# Email Configuration (optionnel)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@madavoyage.com
MAIL_FROM_NAME=Mada Voyage

# Payment Gateway (optionnel)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# API Keys (optionnel)
GOOGLE_MAPS_API_KEY=
